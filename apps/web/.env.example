# S3 image upload (used by POST /api/upload)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=
# For images to display: add a bucket policy allowing public GetObject on uploads/* (bucket can have ACLs disabled).
# Optional: custom base URL for uploaded files (e.g. CloudFront). If unset, uses https://<bucket>.s3.<region>.amazonaws.com/
# S3_PUBLIC_BASE_URL=https://your-cdn.example.com
